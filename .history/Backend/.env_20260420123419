DATABASE_URL="postgresql://postgres:postgres@localhost:9000/nebulaarchive?schema=public"
# --- AUTHENTICATION (JWT) ---
# Escolha uma frase longa e aleatória para garantir a segurança dos tokens.
JWT_SECRET="sua_chave_secreta_super_forte_aqui"

